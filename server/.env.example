# Discord Bot の認証トークン
DISCORD_TOKEN=

# Bot が動作するテキストチャンネルの ID
CHANNEL_ID=

# 操作を許可する Discord ユーザー ID（カンマ区切りで複数指定可）
ALLOWED_USER_IDS=

# claude CLI のパス（省略時: claude）
# CLAUDE_PATH=claude

# Gemini API キー（スレッドタイトル自動生成用、省略時: タイトル生成無効）
# GEMINI_API_KEY=

# ワークスペース設定ファイルのパス（省略時: workspaces.json）
# WORKSPACES_FILE=workspaces.json

# /cc workspace add のディレクトリブラウズ起点（省略時: ホームディレクトリ）
# WORKSPACE_BASE_DIR=/home/user/works
